{
  "entities": {
    "Inquiry": {
      "title": "Inquiry",
      "description": "A client inquiry from the contact form",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name of the contact" },
        "email": { "type": "string", "format": "email", "description": "Email address of the contact" },
        "company": { "type": "string", "description": "Company name" },
        "service": { "type": "string", "description": "Type of service requested" },
        "message": { "type": "string", "description": "Message content" },
        "status": { "type": "string", "enum": ["new", "contacted", "resolved"], "description": "Current status of the inquiry" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the inquiry was created" }
      },
      "required": ["name", "email", "service", "message", "status", "createdAt"]
    }
  },
  "firestore": {
    "/inquiries/{inquiryId}": {
      "schema": "Inquiry",
      "description": "Collection of client inquiries"
    }
  }
}
